<section class="trust-row" data-section-id="{{ section.id }}">
  <div class="container trust-row__grid">
    {%- for block in section.blocks -%}
      <div class="trust-row__item" {{ block.shopify_attributes }}>
        <div class="trust-row__icon">{{ block.settings.icon }}</div>
        <div>
          <p class="trust-row__title">{{ block.settings.title }}</p>
          <p class="trust-row__body">{{ block.settings.body }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust row",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji/icon", "default": "🚚" },
        { "type": "text", "id": "title", "label": "Title", "default": "Free US shipping" },
        { "type": "text", "id": "body", "label": "Body", "default": "On orders $49+" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust row",
      "blocks": [
        { "type": "item", "settings": { "icon": "🚚", "title": "Free US shipping", "body": "On orders $49+" } },
        { "type": "item", "settings": { "icon": "🩺", "title": "Vet-reviewed", "body": "Every SKU vetted" } },
        { "type": "item", "settings": { "icon": "🔄", "title": "30-day returns", "body": "No questions asked" } },
        { "type": "item", "settings": { "icon": "💬", "title": "Human support", "body": "Reply within 12h" } }
      ]
    }
  ]
}
{% endschema %}

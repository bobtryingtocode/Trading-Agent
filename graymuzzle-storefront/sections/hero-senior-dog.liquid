<section class="hero" data-section-id="{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <img class="hero__bg"
         src="{{ section.settings.image | image_url: width: 2000 }}"
         alt=""
         loading="eager"
         fetchpriority="high"
         width="2000"
         height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | round }}">
  {%- endif -%}
  <div class="hero__overlay"></div>
  <div class="hero__content container">
    <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    <p class="hero__sub">{{ section.settings.subheading }}</p>
    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_url }}" class="btn btn--primary btn--large">
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}
    <ul class="hero__trust">
      <li>Free US shipping $49+</li>
      <li>30-day returns</li>
      <li>Vet-reviewed picks</li>
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Hero — senior dog",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "For the dogs who raised us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Make his golden years his best." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Orthopedic beds, mobility ramps, and calm-vet-approved essentials, built for dogs 7+." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop the senior essentials" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "Hero — senior dog" }]
}
{% endschema %}

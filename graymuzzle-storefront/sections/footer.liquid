<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <p class="site-footer__wordmark">GrayMuzzle<span class="accent">.</span></p>
      <p class="site-footer__tag">Comfort for the dogs who raised us.</p>
      {%- if section.settings.show_newsletter -%}
        {% form 'customer', class: 'newsletter' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label for="footer-email">Get 10% off + senior dog tips:</label>
          <div class="newsletter__row">
            <input type="email" id="footer-email" name="contact[email]" required placeholder="you@example.com">
            <button type="submit" class="btn btn--primary">Subscribe</button>
          </div>
        {% endform %}
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        <nav class="site-footer__col" aria-label="{{ block.settings.heading }}" {{ block.shopify_attributes }}>
          <p class="site-footer__heading">{{ block.settings.heading }}</p>
          <ul>
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="container site-footer__legal">
    <p>GrayMuzzle Co. is a brand of Revvy LLC. &copy; {{ 'now' | date: '%Y' }} Revvy LLC. All rights reserved.</p>
    <p class="site-footer__small">
      <a href="/pages/terms-of-service">Terms</a> &middot;
      <a href="/pages/privacy-policy">Privacy</a> &middot;
      <a href="/pages/shipping">Shipping</a> &middot;
      <a href="/pages/returns">Returns</a>
    </p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter", "default": true }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    }
  ],
  "presets": [{
    "name": "Footer",
    "blocks": [
      { "type": "menu", "settings": { "heading": "Shop" } },
      { "type": "menu", "settings": { "heading": "Help" } },
      { "type": "menu", "settings": { "heading": "Company" } }
    ]
  }]
}
{% endschema %}

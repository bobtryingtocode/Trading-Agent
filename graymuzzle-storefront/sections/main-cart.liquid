<section class="cart-page container">
  <h1>Your cart</h1>
  {%- if cart.item_count == 0 -%}
    <p>Your cart is empty. <a href="{{ routes.all_products_collection_url }}">Shop senior essentials →</a></p>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post">
      <ul class="cart-items">
        {%- for item in cart.items -%}
          <li class="cart-item">
            <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.image.alt | escape }}" width="80" height="80" loading="lazy">
            <div>
              <a href="{{ item.url }}">{{ item.product.title }}</a>
              {%- if item.variant.title != 'Default Title' -%}<p>{{ item.variant.title }}</p>{%- endif -%}
            </div>
            <div>
              <label>Qty <input type="number" name="updates[]" value="{{ item.quantity }}" min="0"></label>
            </div>
            <div>{{ item.line_price | money }}</div>
          </li>
        {%- endfor -%}
      </ul>
      <div class="cart-footer">
        <button type="submit" name="update" class="btn btn--secondary">Update</button>
        <div class="cart-footer__total">
          <p>Subtotal <strong>{{ cart.total_price | money }}</strong></p>
          <button type="submit" name="checkout" class="btn btn--primary btn--large">Checkout</button>
        </div>
      </div>
    </form>
  {%- endif -%}
</section>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}

<section class="blog container">
  <h1>{{ blog.title }}</h1>
  <div class="blog__grid">
    {%- for article in blog.articles -%}
      <a class="blog-card" href="{{ article.url }}">
        {%- if article.image -%}
          <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.image.alt | escape }}" width="800" height="auto" loading="lazy">
        {%- endif -%}
        <h2>{{ article.title }}</h2>
        <p>{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
